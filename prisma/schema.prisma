// Uchi Prisma schema (SQLite)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  avatarColor  String?  // 頭文字アイコンの背景色 (hex)。未設定なら --accent
  bio          String?
  // 管理者フラグ。初回 /admin-setting で作成した代表アカウントが true になる。
  isAdmin      Boolean  @default(false)
  // 退職フラグ。退職してもデータは残る。ログイン不可・アイコンに斜線表示。
  isRetired    Boolean  @default(false)
  createdAt    DateTime @default(now())

  articles         Article[]
  likes            Like[]
  bookmarks        Bookmark[]
  follows          Follow[]
  sessions         Session[]
  affiliations     UserAffiliation[]
  communityMembers CommunityMember[]
  communityLeftLogs CommunityLeftLog[]
  aiConfigs        UserAIConfig[]
  aiPrompts        UserAIPrompt[]
  aggTemplates     AggregationTemplate[]
  reviews          ArticleReview[]
  posts            Post[]
  postLikes        PostLike[]
  postReactions    PostReaction[]
  comments         Comment[]
  notifications    Notification[]
  // チャット
  chatRoomMembers  ChatRoomMember[]
  chatMessages     ChatMessage[]
  messageReactions MessageReaction[]
  googleOAuthToken GoogleOAuthToken?
}

// Copenhagen Book 準拠のセッションテーブル
model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Article {
  id          String    @id @default(cuid())
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  slug        String    @unique
  title       String
  emoji       String?
  type        String    // "howto" | "diary"  (旧: "tech" | "idea")
  body        String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 予約公開
  scheduledAt DateTime?

  // 閲覧制御
  // visibility: "public" | "friends_only" (旧: "affiliation_in" | "affiliation_out" は廃止)
  visibility               String  @default("public")
  // (レガシー) CSV of affiliation IDs — 旧仕様の名残。新規作成では使用しない
  visibilityAffiliationIds String  @default("")

  // コミュニティ投稿 / 承認ワークフロー
  communityId    String?
  community      Community? @relation(fields: [communityId], references: [id])
  timelineId     String?
  timeline       CommunityTimeline? @relation(fields: [timelineId], references: [id])
  approvalStatus String   @default("approved") // "draft" | "pending" | "approved" | "rejected"
  approvalNote   String?

  topics    ArticleTopic[]
  likes     Like[]
  bookmarks Bookmark[]
  reviews   ArticleReview[]
  comments  Comment[]

  @@index([authorId])
  @@index([published, publishedAt])
  @@index([communityId])
  @@index([timelineId])
  @@index([scheduledAt])
}

model Topic {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  articles ArticleTopic[]
}

model ArticleTopic {
  articleId String
  topicId   String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([articleId, topicId])
  @@index([topicId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  user      User    @relation(fields: [userId], references: [id])
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([articleId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  user      User    @relation(fields: [userId], references: [id])
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([articleId])
}

model Follow {
  id         String   @id @default(cuid())
  userId     String
  targetType String   // "user" | "topic"
  targetId   String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

// ============================================================
// 所属 (タグ的な存在 — チームを表す)
// ============================================================

model Affiliation {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  users UserAffiliation[]
}

model UserAffiliation {
  userId        String
  affiliationId String
  createdAt     DateTime @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  affiliation   Affiliation @relation(fields: [affiliationId], references: [id], onDelete: Cascade)

  @@id([userId, affiliationId])
  @@index([affiliationId])
}

// ============================================================
// コミュニティ
// ============================================================

model Community {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  avatarUrl   String?  // コミュニティアイコン (画像 URL)。未設定なら頭文字フォールバック
  avatarColor String?  // 頭文字アイコンの背景色 (hex, 例: "#5fcfdc")。未設定なら --accent
  // "public" | "private" | "affiliation_in" | "affiliation_out"
  //   public           … 全体に公開
  //   private          … 招待したメンバーのみ
  //   affiliation_in   … 指定の所属に属するユーザーにだけ見える (管理者のみ設定可)
  //   affiliation_out  … 指定の所属に属するユーザーには見えない (管理者のみ設定可)
  visibility               String   @default("private")
  // affiliation_* で参照する所属 ID の CSV
  visibilityAffiliationIds String   @default("")
  createdAt                DateTime @default(now())

  members   CommunityMember[]
  leftLogs  CommunityLeftLog[]
  invites   CommunityInvite[]
  timelines CommunityTimeline[]
  articles  Article[]
  posts     Post[]
}

model CommunityMember {
  userId      String
  communityId String
  // "owner" | "member"
  role        String   @default("member")
  createdAt   DateTime @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@id([userId, communityId])
  @@index([communityId])
}

// 過去に private コミュニティを脱退した履歴。
// private コミュニティは非メンバーから存在を隠すため、脱退すると一覧から消えてしまう。
// 「設定 > プライベートコミュニティ」タブで自分が抜けた private コミュニティだけ
// 再表示・再参加できるようにするためのテーブル。
model CommunityLeftLog {
  id          String   @id @default(cuid())
  userId      String
  communityId String
  leftAt      DateTime @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@index([userId])
}

model CommunityInvite {
  id          String    @id @default(cuid())
  communityId String
  email       String?
  token       String    @unique
  acceptedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
}

model CommunityTimeline {
  id          String   @id @default(cuid())
  communityId String
  name        String
  // "open" | "private"
  //   open    … コミュニティメンバー全員が閲覧・投稿可能
  //   private … TLメンバー (visibilityUserIds) + コミュニティ owner のみ
  visibility  String   @default("open")
  visibilityAffiliationIds String @default("") // レガシー (未使用)
  // private TL のメンバー ID (CSV)
  visibilityUserIds        String @default("")
  createdAt   DateTime @default(now())
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  articles    Article[]
  posts       Post[]

  @@index([communityId])
}

// ============================================================
// 集約テンプレート
// ============================================================

model AggregationTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  body      String   // Markdown 雛形。{{articles}} プレースホルダで集約位置を指定
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// AI 設定 (per-user)
// ============================================================

model UserAIConfig {
  id        String   @id @default(cuid())
  userId    String
  // "openai" | "anthropic" | "gemini"
  provider  String
  endpoint  String?  // 省略時は各社デフォルト
  model     String
  apiKeyEnc String   // AES-256-GCM 暗号化済み (iv:tag:cipher hex)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserAIPrompt {
  id        String   @id @default(cuid())
  userId    String
  // "review" | "summary"
  kind      String
  body      String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
}

// ============================================================
// AI レビュー (履歴)
// ============================================================

model ArticleReview {
  id        String   @id @default(cuid())
  articleId String
  userId    String   // レビュー実行者
  // JSON 文字列: { summary, goodPoints[], improvements[], lineComments: [{line, body}] }
  payload   String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

// ============================================================
// SNS 投稿 (Post) — Article (Markdown 長文記事) と別概念。
// コミュニティタイムラインに流れる Twitter 風の短文投稿。
// ============================================================

model Post {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  // どのコミュニティ／タイムラインに投稿されたか (NULL = グローバル投稿は今は使わない予定)
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  timelineId  String?
  timeline    CommunityTimeline? @relation(fields: [timelineId], references: [id], onDelete: SetNull)
  // 親投稿 (リプライ用、Phase 後半で使う)
  parentPostId String?
  parentPost   Post?    @relation("PostReplies", fields: [parentPostId], references: [id])
  replies      Post[]   @relation("PostReplies")
  title       String?  // エディタ経由の本格投稿にはタイトルが付く (PostComposer 経由は null)
  body        String   // 文字数制限なし。クライアントで 600 字を超えたら fold
  // member 投稿は owner 承認が要るかどうか (community の運用で決まる)
  approvalStatus String @default("approved") // "approved" | "pending" | "rejected"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  likes    PostLike[]
  reactions PostReaction[]
  comments Comment[]

  @@index([communityId])
  @@index([timelineId])
  @@index([authorId])
  @@index([parentPostId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

// ============================================================
// コメント (Article + Post 両方に付く)
// 親→子のみ。孫はインデントせず子と同階層に並ぶ運用 (UI 側で制御)
// ============================================================

model Comment {
  id              String   @id @default(cuid())
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
  body            String   // markdown
  // どちらか一方が入る
  articleId       String?
  article         Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  postId          String?
  post            Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  // 親コメント (返信時)
  parentCommentId String?
  parentComment   Comment? @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         Comment[] @relation("CommentReplies")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([articleId])
  @@index([postId])
  @@index([parentCommentId])
}

// ============================================================
// 通知
// ============================================================

model Notification {
  id          String   @id @default(cuid())
  // 通知の受信者
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // アクションの主体
  actorId     String
  // 種別: like_article | like_post | bookmark_article | follow_user | comment_article | comment_post
  kind        String
  // ターゲットの記事 / 投稿 / コメントへのリンク (該当しないものは null)
  articleId   String?
  postId      String?
  commentId   String?
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// ============================================================
// チャット (Rocket.Chat IRoom / IMessage / ISubscription 参考)
// ============================================================

model ChatRoom {
  id          String   @id @default(cuid())
  name        String
  description String?
  emoji       String?
  avatarUrl   String?
  visibility  String   @default("private")
  lastMessageId      String?
  lastMessageAt      DateTime?
  lastMessageBody    String?
  lastMessageAuthor  String?
  messageCount       Int       @default(0)
  createdById        String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  members  ChatRoomMember[]
  messages ChatMessage[]
  @@index([visibility])
  @@index([lastMessageAt])
}

model ChatRoomMember {
  userId      String
  roomId      String
  role        String   @default("member")
  unreadCount Int      @default(0)
  lastReadAt  DateTime @default(now())
  favorite    Boolean  @default(false)
  notifyLevel String   @default("all")
  joinedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room        ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  @@id([userId, roomId])
  @@index([roomId])
  @@index([userId, lastReadAt])
}

model ChatMessage {
  id        String    @id @default(cuid())
  roomId    String
  authorId  String
  body      String
  type      String    @default("user")
  editedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  room      ChatRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author    User            @relation(fields: [authorId], references: [id])
  reactions MessageReaction[]
  @@index([roomId, createdAt])
  @@index([authorId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([postId, userId, emoji])
  @@index([postId])
}

model CustomEmoji {
  id          String   @id @default(cuid())
  name        String   @unique
  aliases     String   @default("")
  fileUrl     String
  createdById String
  createdAt   DateTime @default(now())
  @@index([createdById])
}

model GoogleOAuthToken {
  id              String   @id @default(cuid())
  userId          String   @unique
  accessTokenEnc  String
  refreshTokenEnc String
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
