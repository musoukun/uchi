// Benn Prisma schema (SQLite)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  bio          String?
  createdAt    DateTime @default(now())

  articles  Article[]
  likes     Like[]
  bookmarks Bookmark[]
  follows   Follow[]
  sessions  Session[]
}

// Copenhagen Book 準拠のセッションテーブル
// id: crypto.randomBytes(20).toString('base64url') の 160bit ランダム値
model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Article {
  id          String    @id @default(cuid())
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  slug        String    @unique
  title       String
  emoji       String?
  type        String    // "tech" | "idea"
  body        String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  topics    ArticleTopic[]
  likes     Like[]
  bookmarks Bookmark[]

  @@index([authorId])
  @@index([published, publishedAt])
}

model Topic {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  articles ArticleTopic[]
}

// 多対多 (Article <-> Topic)
model ArticleTopic {
  articleId String
  topicId   String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([articleId, topicId])
  @@index([topicId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  user      User    @relation(fields: [userId], references: [id])
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([articleId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  user      User    @relation(fields: [userId], references: [id])
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([articleId])
}

model Follow {
  id         String   @id @default(cuid())
  userId     String
  targetType String   // "user" | "topic"
  targetId   String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}
